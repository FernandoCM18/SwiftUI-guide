---
// Replicates Starlight's MarkdownContent and appends a reading-progress button.
import '../styles/reading-progress.css';
---

<div class="sl-markdown-content">
  <slot />
</div>

<div id="rp-container">
  <button id="rp-btn" type="button" aria-pressed="false">Marcar como leído</button>
</div>

<script>
  const STORAGE_KEY = 'swiftui-guide-read-v1';

  function getLang() {
    return /\/en\//.test(window.location.pathname) ? 'en' : 'es';
  }

  function label(key) {
    const lang = getLang();
    if (key === 'read') return lang === 'en' ? '✓ Read' : '✓ Leído';
    return lang === 'en' ? 'Mark as read' : 'Marcar como leído';
  }

  function getReadPages() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch { return []; }
  }

  function setReadPages(pages) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(pages));
  }

  function isRead(path) {
    return getReadPages().includes(path);
  }

  function toggleRead(path) {
    const pages = getReadPages();
    const i = pages.indexOf(path);
    if (i === -1) pages.push(path);
    else pages.splice(i, 1);
    setReadPages(pages);
    return i === -1;
  }

  function updateBtn(btn, read) {
    btn.textContent = label(read ? 'read' : 'mark');
    btn.dataset.read = String(read);
    btn.setAttribute('aria-pressed', String(read));
  }

  function updateSidebar() {
    const readPages = getReadPages();
    document.querySelectorAll('.sidebar-content a[href]').forEach(link => {
      try {
        const path = new URL(link.href, location.origin).pathname;
        if (readPages.includes(path)) {
          link.setAttribute('data-rp-read', 'true');
        } else {
          link.removeAttribute('data-rp-read');
        }
      } catch (_) {}
    });
  }

  function init() {
    const btn = document.getElementById('rp-btn');
    if (!btn || btn.dataset.initialized) return;
    btn.dataset.initialized = 'true';

    const path = window.location.pathname;
    updateBtn(btn, isRead(path));
    updateSidebar();

    btn.addEventListener('click', () => {
      const newState = toggleRead(path);
      updateBtn(btn, newState);
      updateSidebar();
    });

    if (!isRead(path)) {
      const onScroll = () => {
        const reached = window.scrollY + window.innerHeight >=
          document.documentElement.scrollHeight * 0.9;
        if (reached) {
          window.removeEventListener('scroll', onScroll);
          const btn2 = document.getElementById('rp-btn');
          if (btn2 && !isRead(path)) {
            toggleRead(path);
            updateBtn(btn2, true);
            updateSidebar();
          }
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  }

  // Astro bundles and defers this script automatically.
  // DOMContentLoaded covers the initial load; astro:page-load covers
  // client-side navigations (View Transitions, if ever enabled).
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>
